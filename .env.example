# Firebase Configuration
# Find these values in the Firebase Console → Project Settings → Your Apps → SDK setup and configuration

FIREBASE_API_KEY=                    # Web API key for authenticating Firebase requests
FIREBASE_AUTH_DOMAIN=                # OAuth redirect domain — typically <project-id>.firebaseapp.com
FIREBASE_PROJECT_ID=                 # Unique identifier for your Firebase project
FIREBASE_STORAGE_BUCKET=             # Cloud Storage bucket — typically <project-id>.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=        # Sender ID for Firebase Cloud Messaging (FCM)
FIREBASE_MEASUREMENT_ID=             # Google Analytics measurement ID — only required if Analytics is enabled
